#!/usr/bin/env node

const { program } = require('commander');
const { version } = require('../package.json');
const InteractiveUI = require('../ui/interactive');

// 设置程序基本信息
program
  .name('coclaw')
  .description('Local network AI collaboration tool based on OpenClaw')
  .version(version, '-V, --version')
  .helpOption('-H, --help', '显示帮助信息');

// 基础命令
program
  .command('list')
  .description('显示当前电脑上所有 Agent 的 ID 列表')
  .action(() => {
    require('../lib/commands/list').run();
  });

program
  .command('server')
  .description('启动或停止服务器（后台运行）')
  .action(() => {
    require('../lib/commands/server').run();
  });

program
  .command('create')
  .description('创建新 Agent')
  .action(() => {
    require('../lib/commands/create').run();
  });

program
  .command('connect <serverid>')
  .description('连接到局域网中的其他服务器')
  .action((serverid) => {
    require('../lib/commands/connect').run(serverid);
  });

// Agent 操作命令
program
  .command('agent <id> <action>')
  .description('Agent 操作命令')
  .action((id, action) => {
    require('../lib/commands/agent').run(id, action);
  });

// 性能监控命令
program
  .command('performance')
  .description('查看服务器性能统计')
  .option('-r, --reset', '重置性能统计')
  .option('-d, --disable', '禁用性能优化')
  .option('-e, --enable', '启用性能优化')
  .action((options) => {
    require('../lib/commands/performance').run(options);
  });

// 错误监控命令
program
  .command('errors')
  .description('查看错误统计和日志')
  .option('-c, --clear', '清除错误统计')
  .option('-l, --list', '列出最近错误')
  .option('-s, --stats', '显示错误统计')
  .action((options) => {
    require('../lib/commands/errors').run(options);
  });

// 如果没有提供命令，进入交互模式
if (process.argv.length <= 2) {
  InteractiveUI.start().catch(error => {
    console.error('交互模式启动失败:', error.message);
    process.exit(1);
  });
} else {
  program.parse(process.argv);
}

// 错误处理
process.on('uncaughtException', (error) => {
  console.error('未捕获的异常:', error.message);
  if (process.env.DEBUG) {
    console.error(error.stack);
  }
  process.exit(1);
});

process.on('unhandledRejection', (reason, promise) => {
  console.error('未处理的 Promise 拒绝:', reason);
  process.exit(1);
});